# Frigate Identity Service - Environment Configuration
# Copy this file to .env and configure for your environment

# MQTT Broker Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Frigate API Configuration
FRIGATE_HOST=http://localhost:5000

# ReID Model Configuration
REID_MODEL=osnet_x1_0
REID_DEVICE=auto
REID_SIMILARITY_THRESHOLD=0.6

# Storage Configuration
EMBEDDINGS_DB_PATH=embeddings.json

# Snapshot Correlation Configuration
SNAPSHOT_CORRELATION_WINDOW=2.0
MAX_TRACKED_PERSONS_PER_CAMERA=3

# Confidence Decay Configuration
# Time before confidence starts decaying (in minutes)
CONFIDENCE_DECAY_START_MINUTES=5.0
# Time when confidence reaches zero (in minutes)
CONFIDENCE_DECAY_FULL_MINUTES=15.0
# Rate of confidence decay per minute after decay_start_minutes (0.0-1.0)
CONFIDENCE_DECAY_RATE_PER_MINUTE=0.10
