# Frigate Identity Service - Environment Configuration
# Copy this file to .env and configure for your environment

# MQTT Broker Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Frigate API Configuration
FRIGATE_HOST=http://localhost:5000

# ReID Model Configuration
REID_MODEL=osnet_x1_0
REID_DEVICE=auto
REID_SIMILARITY_THRESHOLD=0.75

# Storage Configuration
# For local development: embeddings.json (default)
# For Docker/containers: /data/embeddings.json (auto-detected)
# Custom path: set explicitly
EMBEDDINGS_DB_PATH=embeddings.json

# Snapshot Correlation Configuration
SNAPSHOT_CORRELATION_WINDOW=2.0
MAX_TRACKED_PERSONS_PER_CAMERA=3
