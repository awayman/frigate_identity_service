# Frigate Identity Service - Environment Configuration
# Copy this file to .env and configure for your environment

# MQTT Broker Configuration
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Frigate API Configuration
FRIGATE_HOST=http://localhost:5000

# ReID Model Configuration
REID_MODEL=osnet_x1_0
REID_DEVICE=auto
REID_SIMILARITY_THRESHOLD=0.6

# Storage Configuration
EMBEDDINGS_DB_PATH=embeddings.json

# Snapshot Correlation Configuration
SNAPSHOT_CORRELATION_WINDOW=2.0
MAX_TRACKED_PERSONS_PER_CAMERA=3

# Spatial Correlation Weights (automatically normalized to sum to 1.0)
# Controls the balance between temporal (time-based) and spatial (bounding box) correlation
TEMPORAL_CORRELATION_WEIGHT=0.6  # Weight for time-based matching (default: 0.6)
SPATIAL_CORRELATION_WEIGHT=0.4   # Weight for bounding box overlap matching (default: 0.4)
